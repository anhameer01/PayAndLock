  "ownerName": "Vikram Sethi",
  "mobile": "9988776655",
  "alternateMobile": "9988776654",
  "address": "Shop No. 5, City mall",
  "city": "Mumbai",
  "state": "Maharashtra",
  "assignedBdmId": "{{employeeId}}",
  "installDate": "2025-01-15",
  "status": "Active"
}

