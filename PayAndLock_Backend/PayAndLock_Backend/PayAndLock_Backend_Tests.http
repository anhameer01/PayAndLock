@baseUrl = http://localhost:5014
@token = 
@adminId = 
@employeeId = 
@retailerId = 
@billingId = 

###
### AUTH ENDPOINTS
###

### Register Admin
POST {{baseUrl}}/api/auth/register-admin
Content-Type: application/json

{
  "loginId": "admin@payandlock",
  "password": "Admin@123"
}

###

### Login Admin
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "loginId": "admin@payandlock",
  "password": "Admin@123"
}

###

### Login BDM Employee
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "loginId": "rajesh.kumar",
  "password": "Employee@123"
}

###
### EMPLOYEE ENDPOINTS
###

### Create Employee - BDM
POST {{baseUrl}}/api/employee
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "fullName": "Rajesh Kumar",
  "loginId": "rajesh.kumar",
  "mobile": "9876543210",
  "password": "Employee@123",
  "role": "BDM",
  "address": "123 Main Street",
  "state": "Maharashtra",
  "city": "Mumbai",
  "monthlyTarget": 50,
  "managerId": null
}

